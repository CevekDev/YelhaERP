// YelhaERP — Schéma Prisma complet
// Multi-tenant : chaque table filtre par companyId

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENTREPRISES (tenant root)
// ============================================================
model Company {
  id           String       @id @default(cuid())
  name         String
  businessType BusinessType @default(NONE)
  legalForm    String?
  nif          String?
  nis          String?
  rc           String?
  aeCardNumber String?
  address      String?
  wilaya       String?
  phone        String?
  email        String?
  bankRib      String?
  plan         Plan         @default(TRIAL)
  aiQuotaUsed  Int          @default(0)
  aiQuotaReset DateTime     @default(now())
  trialEndsAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users           User[]
  clients         Client[]
  suppliers       Supplier[]
  invoices        Invoice[]
  products        Product[]
  stockMovements  StockMovement[]
  journalEntries  JournalEntry[]
  payrollEntries  PayrollEntry[]
  employees       Employee[]
  taxDeclarations TaxDeclaration[]
  aiConversations AiConversation[]
  integrations    Integration[]
  purchaseOrders  PurchaseOrder[]
  quotes          Quote[]
  notifications   Notification[]
  expenses        Expense[]
  clientMessages  ClientMessage[]
}

enum BusinessType {
  RC
  AE
  NONE
}

enum Plan {
  TRIAL
  STARTER
  PRO
  AGENCY
}

// ============================================================
// UTILISATEURS
// ============================================================
model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String?
  name               String
  phone              String?
  birthDate          DateTime?
  emailVerified      DateTime?
  verificationToken  String?   @unique
  verificationExpiry DateTime?
  role               Role      @default(EMPLOYEE)
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  expenses Expense[]

  @@index([companyId])
}

enum Role {
  OWNER
  ADMIN
  ACCOUNTANT
  EMPLOYEE
  READONLY
}

// NextAuth adapters
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CLIENTS
// ============================================================
model Client {
  id          String     @id @default(cuid())
  companyId   String
  clientType  ClientType @default(COMPANY)
  name        String
  firstName   String?
  nif         String?
  nis         String?
  rc          String?
  address     String?
  wilaya      String?
  phone       String?
  email       String?
  description String?    @db.Text
  portalToken String?    @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  quotes   Quote[]
  messages ClientMessage[]

  @@index([companyId])
  @@index([companyId, name])
}

enum ClientType {
  COMPANY
  INDIVIDUAL
}

// ============================================================
// FOURNISSEURS
// ============================================================
model Supplier {
  id        String   @id @default(cuid())
  companyId String
  name      String
  nif       String?
  nis       String?
  rc        String?
  address   String?
  wilaya    String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([companyId])
  @@index([companyId, name])
}

// ============================================================
// FACTURES
// ============================================================
model Invoice {
  id             String        @id @default(cuid())
  companyId      String
  clientId       String
  number         String
  type           InvoiceType
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime
  dueDate        DateTime?
  subtotal       Decimal       @db.Decimal(15, 2)
  taxAmount      Decimal       @db.Decimal(15, 2)
  total          Decimal       @db.Decimal(15, 2)
  currency       String        @default("DZD")
  notes          String?
  isShopifyOrder Boolean       @default(false)
  isWooOrder     Boolean       @default(false)
  externalId     String?
  portalToken    String?       @unique
  quoteId        String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client        @relation(fields: [clientId], references: [id])
  lines   InvoiceLine[]
  quote   Quote?        @relation(fields: [quoteId], references: [id])

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@index([companyId, clientId])
}

enum InvoiceType {
  STANDARD
  SIMPLIFIED
  PROFORMA
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @db.Decimal(5, 2) @default(19)
  total       Decimal @db.Decimal(15, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ============================================================
// DEVIS
// ============================================================
model Quote {
  id           String      @id @default(cuid())
  companyId    String
  clientId     String
  number       String
  status       QuoteStatus @default(DRAFT)
  issueDate    DateTime
  expiryDate   DateTime?
  subtotal     Decimal     @db.Decimal(15, 2)
  taxAmount    Decimal     @db.Decimal(15, 2)
  total        Decimal     @db.Decimal(15, 2)
  notes        String?
  portalToken  String?     @unique
  followUpAt   DateTime?
  followUpCount Int        @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client      @relation(fields: [clientId], references: [id])
  lines   QuoteLine[]
  invoice Invoice?

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

model QuoteLine {
  id          String  @id @default(cuid())
  quoteId     String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @db.Decimal(5, 2) @default(19)
  total       Decimal @db.Decimal(15, 2)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([quoteId])
}

// ============================================================
// PRODUITS & STOCK
// ============================================================
model Product {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  sku         String?
  description String?
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @db.Decimal(5, 2) @default(19)
  stockQty    Decimal @db.Decimal(10, 3) @default(0)
  stockAlert  Decimal @db.Decimal(10, 3) @default(0)
  unit        String?
  isActive    Boolean @default(true)

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
  quoteLines     QuoteLine[]

  @@index([companyId])
  @@index([companyId, sku])
}

model StockMovement {
  id        String       @id @default(cuid())
  companyId String
  productId String
  type      MovementType
  quantity  Decimal      @db.Decimal(10, 3)
  unitCost  Decimal?     @db.Decimal(15, 2)
  reference String?
  note      String?
  createdAt DateTime     @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([companyId, createdAt])
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

// ============================================================
// EMPLOYÉS & PAIE
// ============================================================
model Employee {
  id           String   @id @default(cuid())
  companyId    String
  firstName    String
  lastName     String
  nin          String?
  socialNumber String?
  position     String?
  baseSalary   Decimal  @db.Decimal(15, 2)
  hireDate     DateTime
  isActive     Boolean  @default(true)

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrollEntries PayrollEntry[]

  @@index([companyId])
}

model PayrollEntry {
  id           String  @id @default(cuid())
  companyId    String
  employeeId   String
  month        Int
  year         Int
  baseSalary   Decimal @db.Decimal(15, 2)
  grossSalary  Decimal @db.Decimal(15, 2)
  cnasEmployee Decimal @db.Decimal(15, 2)
  cnasEmployer Decimal @db.Decimal(15, 2)
  irg          Decimal @db.Decimal(15, 2)
  netSalary    Decimal @db.Decimal(15, 2)
  isPaid       Boolean @default(false)

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([companyId, employeeId, month, year])
  @@index([companyId])
  @@index([companyId, year, month])
}

// ============================================================
// COMPTABILITÉ
// ============================================================
model JournalEntry {
  id          String   @id @default(cuid())
  companyId   String
  date        DateTime
  reference   String
  description String
  debit       Decimal  @db.Decimal(15, 2)
  credit      Decimal  @db.Decimal(15, 2)
  accountCode String
  accountName String
  createdAt   DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, accountCode])
}

// ============================================================
// FISCALITÉ
// ============================================================
model TaxDeclaration {
  id        String    @id @default(cuid())
  companyId String
  type      String
  period    String
  amount    Decimal   @db.Decimal(15, 2)
  status    String    @default("PENDING")
  dueDate   DateTime
  paidAt    DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, status])
}

// ============================================================
// DÉPENSES & NOTES DE FRAIS
// ============================================================
model Expense {
  id             String          @id @default(cuid())
  companyId      String
  userId         String
  category       ExpenseCategory
  amount         Decimal         @db.Decimal(15, 2)
  description    String
  date           DateTime
  status         ExpenseStatus   @default(PENDING)
  receiptUrl     String?
  receiptText    String?
  journalEntryId String?
  taxAmount      Decimal?        @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, date])
}

enum ExpenseCategory {
  TRANSPORT
  REPAS
  HEBERGEMENT
  FOURNITURES
  COMMUNICATION
  MAINTENANCE
  PUBLICITE
  FORMATION
  HONORAIRES
  AUTRE
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  EXPORTED
}

// ============================================================
// NOTIFICATIONS
// ============================================================
model Notification {
  id        String           @id @default(cuid())
  companyId String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  priority  String           @default("NORMAL")
  actionUrl String?
  createdAt DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isRead])
  @@index([companyId, createdAt])
}

enum NotificationType {
  FISCAL_DEADLINE
  ANOMALY
  STOCK_ALERT
  INVOICE_OVERDUE
  CASHFLOW_WARNING
  AI_INSIGHT
  QUOTE_EXPIRING
}

// ============================================================
// MESSAGERIE PORTAIL CLIENT
// ============================================================
model ClientMessage {
  id         String   @id @default(cuid())
  companyId  String
  clientId   String
  token      String
  content    String   @db.Text
  fromClient Boolean  @default(true)
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id])

  @@index([companyId, clientId])
  @@index([token])
}

// ============================================================
// IA
// ============================================================
model AiConversation {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  title     String   @default("Nouvelle conversation")
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, userId])
}

// ============================================================
// INTÉGRATIONS (Shopify, WooCommerce)
// ============================================================
model Integration {
  id        String          @id @default(cuid())
  companyId String
  type      IntegrationType
  config    Json
  isActive  Boolean         @default(true)
  lastSync  DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type])
  @@index([companyId])
}

enum IntegrationType {
  SHOPIFY
  WOOCOMMERCE
}

// ============================================================
// BONS DE COMMANDE
// ============================================================
model PurchaseOrder {
  id         String   @id @default(cuid())
  companyId  String
  supplierId String
  number     String
  status     String   @default("DRAFT")
  total      Decimal  @db.Decimal(15, 2)
  orderDate  DateTime
  createdAt  DateTime @default(now())

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier Supplier           @relation(fields: [supplierId], references: [id])
  lines    PurchaseOrderLine[]

  @@index([companyId])
  @@index([companyId, supplierId])
}

model PurchaseOrderLine {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String?
  description     String
  quantity        Decimal @db.Decimal(10, 3)
  unitPrice       Decimal @db.Decimal(15, 2)
  total           Decimal @db.Decimal(15, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}
