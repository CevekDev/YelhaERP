// YelhaERP — Schéma Prisma complet
// Multi-tenant : chaque table filtre par companyId

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENTREPRISES (tenant root)
// ============================================================
model Company {
  id           String       @id @default(cuid())
  name         String
  businessType BusinessType @default(NONE)
  legalForm    String?
  nif          String?
  nis          String?
  rc           String?
  aeCardNumber String?
  address      String?
  wilaya       String?
  phone        String?
  email        String?
  bankRib      String?
  plan         Plan         @default(TRIAL)
  aiQuotaUsed  Int          @default(0)
  aiQuotaReset DateTime     @default(now())
  trialEndsAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users              User[]
  clients            Client[]
  suppliers          Supplier[]
  invoices           Invoice[]
  products           Product[]
  stockMovements     StockMovement[]
  journalEntries     JournalEntry[]
  payrollEntries     PayrollEntry[]
  employees          Employee[]
  taxDeclarations    TaxDeclaration[]
  aiConversations    AiConversation[]
  integrations       Integration[]
  purchaseOrders     PurchaseOrder[]
  quotes             Quote[]
  notifications      Notification[]
  expenses           Expense[]
  clientMessages     ClientMessage[]
  // New modules
  accountsPCN        AccountPCN[]
  accountEntries     AccountEntry[]
  fiscalPeriods      FiscalPeriod[]
  goodsReceipts      GoodsReceipt[]
  supplierInvoices   SupplierInvoice[]
  poApprovals        POApproval[]
  leads              Lead[]
  pipelines          Pipeline[]
  boms               BOM[]
  productionOrders   ProductionOrder[]
  projects           Project[]
  timeLogs           TimeLog[]
  leaveTypes         LeaveType[]
  leaveRequests      LeaveRequest[]
  jobPostings        JobPosting[]
  applications       Application[]
  performanceReviews PerformanceReview[]
  warehouses         Warehouse[]
  stockPositions     StockPosition[]
  stockTransfers     StockTransfer[]
  exchangeRates      ExchangeRate[]
}

enum BusinessType {
  RC
  AE
  NONE
}

enum Plan {
  TRIAL
  STARTER
  PRO
  AGENCY
}

// ============================================================
// UTILISATEURS
// ============================================================
model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String?
  name               String
  phone              String?
  birthDate          DateTime?
  emailVerified      DateTime?
  verificationToken  String?   @unique
  verificationExpiry DateTime?
  role               Role      @default(EMPLOYEE)
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  expenses Expense[]

  @@index([companyId])
}

enum Role {
  OWNER
  ADMIN
  ACCOUNTANT
  EMPLOYEE
  READONLY
}

// NextAuth adapters
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CLIENTS
// ============================================================
model Client {
  id          String     @id @default(cuid())
  companyId   String
  clientType  ClientType @default(COMPANY)
  name        String
  firstName   String?
  nif         String?
  nis         String?
  rc          String?
  address     String?
  wilaya      String?
  phone       String?
  email       String?
  description String?    @db.Text
  portalToken String?    @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  quotes   Quote[]
  messages ClientMessage[]
  leads    Lead[]
  projects Project[]

  @@index([companyId])
  @@index([companyId, name])
}

enum ClientType {
  COMPANY
  INDIVIDUAL
}

// ============================================================
// FOURNISSEURS
// ============================================================
model Supplier {
  id        String   @id @default(cuid())
  companyId String
  name      String
  nif       String?
  nis       String?
  rc        String?
  address   String?
  wilaya    String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrders   PurchaseOrder[]
  supplierInvoices SupplierInvoice[]

  @@index([companyId])
  @@index([companyId, name])
}

// ============================================================
// FACTURES
// ============================================================
model Invoice {
  id             String        @id @default(cuid())
  companyId      String
  clientId       String
  number         String
  type           InvoiceType
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime
  dueDate        DateTime?
  subtotal       Decimal       @db.Decimal(15, 2)
  taxAmount      Decimal       @db.Decimal(15, 2)
  total          Decimal       @db.Decimal(15, 2)
  currency       String        @default("DZD")
  exchangeRate   Decimal?      @db.Decimal(12, 6)
  amountDZD      Decimal?      @db.Decimal(15, 2)
  notes          String?
  isShopifyOrder Boolean       @default(false)
  isWooOrder     Boolean       @default(false)
  externalId     String?
  portalToken    String?       @unique
  quoteId        String?       @unique
  projectId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client        @relation(fields: [clientId], references: [id])
  lines   InvoiceLine[]
  quote   Quote?        @relation(fields: [quoteId], references: [id])
  project Project?      @relation(fields: [projectId], references: [id])

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@index([companyId, clientId])
}

enum InvoiceType {
  STANDARD
  SIMPLIFIED
  PROFORMA
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @db.Decimal(5, 2) @default(19)
  total       Decimal @db.Decimal(15, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ============================================================
// DEVIS
// ============================================================
model Quote {
  id            String      @id @default(cuid())
  companyId     String
  clientId      String
  number        String
  status        QuoteStatus @default(DRAFT)
  issueDate     DateTime
  expiryDate    DateTime?
  subtotal      Decimal     @db.Decimal(15, 2)
  taxAmount     Decimal     @db.Decimal(15, 2)
  total         Decimal     @db.Decimal(15, 2)
  currency      String      @default("DZD")
  exchangeRate  Decimal?    @db.Decimal(12, 6)
  amountDZD     Decimal?    @db.Decimal(15, 2)
  notes         String?
  portalToken   String?     @unique
  followUpAt    DateTime?
  followUpCount Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client      @relation(fields: [clientId], references: [id])
  lines   QuoteLine[]
  invoice Invoice?

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

model QuoteLine {
  id          String  @id @default(cuid())
  quoteId     String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @db.Decimal(5, 2) @default(19)
  total       Decimal @db.Decimal(15, 2)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([quoteId])
}

// ============================================================
// PRODUITS & STOCK
// ============================================================
model Product {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  sku         String?
  description String?
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @db.Decimal(5, 2) @default(19)
  stockQty    Decimal @db.Decimal(10, 3) @default(0)
  stockAlert  Decimal @db.Decimal(10, 3) @default(0)
  unit        String?
  isActive    Boolean @default(true)

  company                Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockMovements         StockMovement[]
  quoteLines             QuoteLine[]
  boms                   BOM[]
  bomComponents          BOMComponent[]
  productionConsumptions ProductionConsumption[]
  stockPositions         StockPosition[]
  transferLines          StockTransferLine[]

  @@index([companyId])
  @@index([companyId, sku])
}

model StockMovement {
  id          String       @id @default(cuid())
  companyId   String
  productId   String
  warehouseId String?
  type        MovementType
  quantity    Decimal      @db.Decimal(10, 3)
  unitCost    Decimal?     @db.Decimal(15, 2)
  reference   String?
  note        String?
  createdAt   DateTime     @default(now())

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([companyId, createdAt])
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

// ============================================================
// EMPLOYÉS & PAIE
// ============================================================
model Employee {
  id           String   @id @default(cuid())
  companyId    String
  firstName    String
  lastName     String
  nin          String?
  socialNumber String?
  position     String?
  department   String?
  managerId    String?
  baseSalary   Decimal  @db.Decimal(15, 2)
  hireDate     DateTime
  isActive     Boolean  @default(true)

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manager            Employee?           @relation("ManagerReports", fields: [managerId], references: [id])
  reports            Employee[]          @relation("ManagerReports")
  payrollEntries     PayrollEntry[]
  leaveRequests      LeaveRequest[]
  performanceReviews PerformanceReview[]

  @@index([companyId])
}

model PayrollEntry {
  id           String  @id @default(cuid())
  companyId    String
  employeeId   String
  month        Int
  year         Int
  baseSalary   Decimal @db.Decimal(15, 2)
  grossSalary  Decimal @db.Decimal(15, 2)
  cnasEmployee Decimal @db.Decimal(15, 2)
  cnasEmployer Decimal @db.Decimal(15, 2)
  irg          Decimal @db.Decimal(15, 2)
  netSalary    Decimal @db.Decimal(15, 2)
  isPaid       Boolean @default(false)

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([companyId, employeeId, month, year])
  @@index([companyId])
  @@index([companyId, year, month])
}

// ============================================================
// COMPTABILITÉ (legacy — simple journal, utilisé par dépenses)
// ============================================================
model JournalEntry {
  id          String   @id @default(cuid())
  companyId   String
  date        DateTime
  reference   String
  description String
  debit       Decimal  @db.Decimal(15, 2)
  credit      Decimal  @db.Decimal(15, 2)
  accountCode String
  accountName String
  createdAt   DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, accountCode])
}

// ============================================================
// COMPTABILITÉ PCN (Plan Comptable National algérien)
// ============================================================
model AccountPCN {
  id         String      @id @default(cuid())
  companyId  String
  code       String
  name       String
  class      Int
  type       AccountType
  isActive   Boolean     @default(true)
  parentCode String?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountLines AccountLine[]

  @@unique([companyId, code])
  @@index([companyId, class])
}

enum AccountType {
  ACTIF
  PASSIF
  CHARGE
  PRODUIT
}

model AccountEntry {
  id          String   @id @default(cuid())
  companyId   String
  date        DateTime
  reference   String
  description String
  period      String
  isClosed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   AccountLine[]

  @@index([companyId, period])
  @@index([companyId, date])
}

model AccountLine {
  id          String  @id @default(cuid())
  entryId     String
  accountCode String
  accountId   String
  description String
  debit       Decimal @db.Decimal(15, 2) @default(0)
  credit      Decimal @db.Decimal(15, 2) @default(0)

  entry   AccountEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account AccountPCN   @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
}

model FiscalPeriod {
  id        String    @id @default(cuid())
  companyId String
  year      Int
  month     Int
  isClosed  Boolean   @default(false)
  closedAt  DateTime?
  closedBy  String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, year, month])
  @@index([companyId])
}

// ============================================================
// FISCALITÉ
// ============================================================
model TaxDeclaration {
  id        String    @id @default(cuid())
  companyId String
  type      String
  period    String
  amount    Decimal   @db.Decimal(15, 2)
  status    String    @default("PENDING")
  dueDate   DateTime
  paidAt    DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, status])
}

// ============================================================
// DÉPENSES & NOTES DE FRAIS
// ============================================================
model Expense {
  id             String          @id @default(cuid())
  companyId      String
  userId         String
  category       ExpenseCategory
  amount         Decimal         @db.Decimal(15, 2)
  currency       String          @default("DZD")
  exchangeRate   Decimal?        @db.Decimal(12, 6)
  amountDZD      Decimal?        @db.Decimal(15, 2)
  description    String
  date           DateTime
  status         ExpenseStatus   @default(PENDING)
  receiptUrl     String?
  receiptText    String?
  journalEntryId String?
  taxAmount      Decimal?        @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, date])
}

enum ExpenseCategory {
  TRANSPORT
  REPAS
  HEBERGEMENT
  FOURNITURES
  COMMUNICATION
  MAINTENANCE
  PUBLICITE
  FORMATION
  HONORAIRES
  AUTRE
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  EXPORTED
}

// ============================================================
// NOTIFICATIONS
// ============================================================
model Notification {
  id        String           @id @default(cuid())
  companyId String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  priority  String           @default("NORMAL")
  actionUrl String?
  createdAt DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isRead])
  @@index([companyId, createdAt])
}

enum NotificationType {
  FISCAL_DEADLINE
  ANOMALY
  STOCK_ALERT
  INVOICE_OVERDUE
  CASHFLOW_WARNING
  AI_INSIGHT
  QUOTE_EXPIRING
  LEAVE_REQUEST_PENDING
  LEAD_STAGE_CHANGED
  PO_APPROVAL_NEEDED
  PRODUCTION_ORDER_DELAYED
  PROJECT_BUDGET_EXCEEDED
}

// ============================================================
// MESSAGERIE PORTAIL CLIENT
// ============================================================
model ClientMessage {
  id         String   @id @default(cuid())
  companyId  String
  clientId   String
  token      String
  content    String   @db.Text
  fromClient Boolean  @default(true)
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id])

  @@index([companyId, clientId])
  @@index([token])
}

// ============================================================
// IA
// ============================================================
model AiConversation {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  title     String   @default("Nouvelle conversation")
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, userId])
}

// ============================================================
// INTÉGRATIONS (Shopify, WooCommerce)
// ============================================================
model Integration {
  id        String          @id @default(cuid())
  companyId String
  type      IntegrationType
  config    Json
  isActive  Boolean         @default(true)
  lastSync  DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type])
  @@index([companyId])
}

enum IntegrationType {
  SHOPIFY
  WOOCOMMERCE
}

// ============================================================
// BONS DE COMMANDE & ACHATS
// ============================================================
model PurchaseOrder {
  id         String    @id @default(cuid())
  companyId  String
  supplierId String
  number     String
  status     POStatus  @default(DRAFT)
  subtotal   Decimal   @db.Decimal(15, 2) @default(0)
  taxAmount  Decimal   @db.Decimal(15, 2) @default(0)
  total      Decimal   @db.Decimal(15, 2)
  orderDate  DateTime
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier         Supplier             @relation(fields: [supplierId], references: [id])
  lines            PurchaseOrderLine[]
  goodsReceipts    GoodsReceipt[]
  supplierInvoices SupplierInvoice[]
  approvals        POApproval[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, supplierId])
  @@index([companyId, status])
}

enum POStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  INVOICED
  CANCELLED
}

model PurchaseOrderLine {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String?
  description     String
  quantity        Decimal @db.Decimal(10, 3)
  unitPrice       Decimal @db.Decimal(15, 2)
  taxRate         Decimal @db.Decimal(5, 2) @default(19)
  total           Decimal @db.Decimal(15, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model GoodsReceipt {
  id              String   @id @default(cuid())
  companyId       String
  purchaseOrderId String
  number          String
  receivedDate    DateTime
  warehouseId     String?
  status          String   @default("PENDING")
  notes           String?
  createdAt       DateTime @default(now())

  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  warehouse     Warehouse?         @relation(fields: [warehouseId], references: [id])
  lines         GoodsReceiptLine[]
  supplierInvoices SupplierInvoice[]

  @@index([companyId])
  @@index([companyId, purchaseOrderId])
}

model GoodsReceiptLine {
  id          String  @id @default(cuid())
  receiptId   String
  productId   String?
  description String
  orderedQty  Decimal @db.Decimal(10, 3)
  receivedQty Decimal @db.Decimal(10, 3)
  unitCost    Decimal @db.Decimal(15, 2)

  receipt GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
}

model SupplierInvoice {
  id              String                @id @default(cuid())
  companyId       String
  supplierId      String
  purchaseOrderId String?
  receiptId       String?
  number          String
  invoiceDate     DateTime
  dueDate         DateTime?
  subtotal        Decimal               @db.Decimal(15, 2)
  taxAmount       Decimal               @db.Decimal(15, 2)
  total           Decimal               @db.Decimal(15, 2)
  status          SupplierInvoiceStatus @default(PENDING)
  matchingStatus  String                @default("UNMATCHED")
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier      Supplier              @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  receipt       GoodsReceipt?         @relation(fields: [receiptId], references: [id])
  lines         SupplierInvoiceLine[]

  @@index([companyId, status])
  @@index([companyId, supplierId])
}

enum SupplierInvoiceStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model SupplierInvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @db.Decimal(5, 2) @default(19)
  total       Decimal @db.Decimal(15, 2)

  invoice SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model POApproval {
  id              String    @id @default(cuid())
  companyId       String
  purchaseOrderId String
  step            Int
  approverRole    Role
  approverId      String?
  status          String    @default("PENDING")
  comment         String?
  decidedAt       DateTime?

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([companyId, purchaseOrderId])
}

// ============================================================
// CRM — LEADS & PIPELINE
// ============================================================
model Lead {
  id             String     @id @default(cuid())
  companyId      String
  firstName      String?
  lastName       String
  company        String?
  email          String?
  phone          String?
  source         LeadSource @default(MANUAL)
  stage          LeadStage  @default(NEW)
  score          Int        @default(0)
  expectedValue  Decimal?   @db.Decimal(15, 2)
  expectedClose  DateTime?
  assignedTo     String?
  notes          String?    @db.Text
  lostReason     String?
  convertedAt    DateTime?
  clientId       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  companyRel  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client      Client?        @relation(fields: [clientId], references: [id])
  activities  LeadActivity[]
  tasks       LeadTask[]

  @@index([companyId, stage])
  @@index([companyId, assignedTo])
}

enum LeadSource {
  MANUAL
  WEBSITE
  REFERRAL
  SHOPIFY
  WOOCOMMERCE
  PHONE
  EMAIL
  SOCIAL
  OTHER
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model LeadActivity {
  id       String       @id @default(cuid())
  leadId   String
  userId   String
  type     ActivityType
  subject  String
  notes    String?      @db.Text
  doneAt   DateTime     @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
}

model LeadTask {
  id         String    @id @default(cuid())
  leadId     String
  title      String
  dueDate    DateTime?
  isDone     Boolean   @default(false)
  assignedTo String?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Pipeline {
  id        String  @id @default(cuid())
  companyId String
  name      String
  stages    Json
  isDefault Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ============================================================
// PRODUCTION & FABRICATION (BOM)
// ============================================================
model BOM {
  id        String   @id @default(cuid())
  companyId String
  productId String
  name      String
  version   String   @default("1.0")
  isActive  Boolean  @default(true)
  yieldQty  Decimal  @db.Decimal(10, 3) @default(1)
  createdAt DateTime @default(now())

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product          Product           @relation(fields: [productId], references: [id])
  components       BOMComponent[]
  productionOrders ProductionOrder[]

  @@index([companyId, productId])
}

model BOMComponent {
  id        String  @id @default(cuid())
  bomId     String
  productId String
  quantity  Decimal @db.Decimal(10, 3)
  unit      String?
  notes     String?

  bom     BOM     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([bomId])
}

model ProductionOrder {
  id             String           @id @default(cuid())
  companyId      String
  bomId          String
  number         String
  status         ProductionStatus @default(DRAFT)
  plannedQty     Decimal          @db.Decimal(10, 3)
  producedQty    Decimal          @db.Decimal(10, 3) @default(0)
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  notes          String?
  createdAt      DateTime         @default(now())

  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bom          BOM                    @relation(fields: [bomId], references: [id])
  consumptions ProductionConsumption[]

  @@unique([companyId, number])
  @@index([companyId, status])
}

enum ProductionStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
}

model ProductionConsumption {
  id               String  @id @default(cuid())
  productionOrderId String
  productId        String
  plannedQty       Decimal @db.Decimal(10, 3)
  consumedQty      Decimal @db.Decimal(10, 3) @default(0)

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])

  @@index([productionOrderId])
}

// ============================================================
// GESTION DE PROJET & FEUILLES DE TEMPS
// ============================================================
model Project {
  id          String         @id @default(cuid())
  companyId   String
  clientId    String?
  name        String
  code        String?
  status      ProjectStatus  @default(ACTIVE)
  description String?        @db.Text
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?       @db.Decimal(15, 2)
  billingType ProjectBilling @default(FIXED)
  hourlyRate  Decimal?       @db.Decimal(10, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company  Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client   Client?       @relation(fields: [clientId], references: [id])
  tasks    ProjectTask[]
  timeLogs TimeLog[]
  invoices Invoice[]

  @@index([companyId, status])
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectBilling {
  FIXED
  HOURLY
  MILESTONE
}

model ProjectTask {
  id             String     @id @default(cuid())
  projectId      String
  title          String
  description    String?    @db.Text
  status         TaskStatus @default(TODO)
  priority       String     @default("NORMAL")
  assignedTo     String?
  dueDate        DateTime?
  estimatedHours Decimal?   @db.Decimal(6, 2)
  completedAt    DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeLogs TimeLog[]

  @@index([projectId, status])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

model TimeLog {
  id          String   @id @default(cuid())
  companyId   String
  projectId   String
  taskId      String?
  userId      String
  date        DateTime
  hours       Decimal  @db.Decimal(6, 2)
  description String
  isBillable  Boolean  @default(true)
  isInvoiced  Boolean  @default(false)

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id])
  task    ProjectTask? @relation(fields: [taskId], references: [id])

  @@index([companyId, projectId])
  @@index([companyId, userId, date])
}

// ============================================================
// RH AVANCÉE — CONGÉS, RECRUTEMENT, ÉVALUATIONS
// ============================================================
model LeaveType {
  id             String @id @default(cuid())
  companyId      String
  name           String
  maxDaysPerYear Int    @default(30)
  isPaid         Boolean @default(true)

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requests LeaveRequest[]

  @@index([companyId])
}

model LeaveRequest {
  id             String      @id @default(cuid())
  companyId      String
  employeeId     String
  leaveTypeId    String
  startDate      DateTime
  endDate        DateTime
  days           Int
  reason         String?
  status         LeaveStatus @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime    @default(now())

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([companyId, status])
  @@index([employeeId])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model JobPosting {
  id           String        @id @default(cuid())
  companyId    String
  title        String
  department   String?
  description  String?       @db.Text
  requirements String?       @db.Text
  status       PostingStatus @default(OPEN)
  closingDate  DateTime?
  createdAt    DateTime      @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([companyId, status])
}

enum PostingStatus {
  OPEN
  CLOSED
  ON_HOLD
}

model Application {
  id        String           @id @default(cuid())
  postingId String
  companyId String
  firstName String
  lastName  String
  email     String
  phone     String?
  cvUrl     String?
  stage     ApplicationStage @default(NEW)
  notes     String?          @db.Text
  createdAt DateTime         @default(now())

  posting JobPosting @relation(fields: [postingId], references: [id], onDelete: Cascade)
  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([postingId, stage])
}

enum ApplicationStage {
  NEW
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

model PerformanceReview {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  reviewerId   String
  period       String
  score        Int?
  objectives   Json?
  strengths    String?  @db.Text
  improvements String?  @db.Text
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([companyId, employeeId])
}

// ============================================================
// MULTI-ENTREPÔTS
// ============================================================
model Warehouse {
  id        String  @id @default(cuid())
  companyId String
  name      String
  code      String
  address   String?
  wilaya    String?
  isDefault Boolean @default(false)

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locations      WarehouseLocation[]
  stockMovements StockMovement[]
  goodsReceipts  GoodsReceipt[]
  fromTransfers  StockTransfer[]     @relation("FromWarehouse")
  toTransfers    StockTransfer[]     @relation("ToWarehouse")

  @@unique([companyId, code])
  @@index([companyId])
}

model WarehouseLocation {
  id          String  @id @default(cuid())
  warehouseId String
  name        String
  barcode     String?

  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockPositions StockPosition[]

  @@index([warehouseId])
}

model StockPosition {
  id         String  @id @default(cuid())
  companyId  String
  productId  String
  locationId String
  quantity   Decimal @db.Decimal(10, 3) @default(0)

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id])
  location WarehouseLocation @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId])
  @@index([companyId])
}

model StockTransfer {
  id              String         @id @default(cuid())
  companyId       String
  fromWarehouseId String
  toWarehouseId   String
  status          TransferStatus @default(DRAFT)
  scheduledDate   DateTime?
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime       @default(now())

  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  lines         StockTransferLine[]

  @@index([companyId, status])
}

enum TransferStatus {
  DRAFT
  CONFIRMED
  IN_TRANSIT
  DONE
  CANCELLED
}

model StockTransferLine {
  id           String  @id @default(cuid())
  transferId   String
  productId    String
  requestedQty Decimal @db.Decimal(10, 3)
  doneQty      Decimal @db.Decimal(10, 3) @default(0)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id])

  @@index([transferId])
}

// ============================================================
// MULTI-DEVISES
// ============================================================
model Currency {
  id     String  @id @default(cuid())
  code   String  @unique
  name   String
  symbol String
  isBase Boolean @default(false)
}

model ExchangeRate {
  id           String   @id @default(cuid())
  companyId    String
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(12, 6)
  date         DateTime
  source       String   @default("MANUAL")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, fromCurrency, toCurrency, date])
  @@index([companyId, date])
}
