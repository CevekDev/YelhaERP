# ============================================================
# YelhaERP — Variables d'environnement (exemple)
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans le dépôt git
# ============================================================

# Base de données (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="[générer avec: openssl rand -base64 32]"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[project].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon key]"
SUPABASE_SERVICE_ROLE_KEY="[service role key — ne jamais exposer côté client]"

# DeepSeek IA
DEEPSEEK_API_KEY="[votre clé DeepSeek]"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL="https://[endpoint].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[token]"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="[email]"
SMTP_PASS="[app password]"
EMAIL_FROM="noreply@yelhaerp.dz"

# Shopify (configuré par entreprise, pas ici)
# Ces valeurs sont stockées chiffrées dans la table Integration

# Chargily Pay (paiement en ligne EDAHABIA / CIB)
# Créer un compte sur https://pay.chargily.net et récupérer les clés API
CHARGILY_SECRET_KEY="test_sk_[votre_clé_secrète_chargily]"
# "test" pour le mode test, "live" pour la production
CHARGILY_MODE="test"

# Environnement
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
